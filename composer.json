{
    "name": "ggpsystems/geoplace",
    "description": "GeoPlace API download proxy",
    "type": "project",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Murray Crane",
            "email": "murray.crane@ggpsystems.co.uk"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.9",
        "symfony/http-foundation": "^7.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.59",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "GgpSystems\\GeoPlace\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GgpSystems\\GeoPlace\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
